from flask import jsonify, request

from ...auth import mechanic_token_required, token_required
from ...extensions import cache, db
from ...models import Inventory, Mechanic, ServiceTicket
from . import service_ticket_bp
from .schemas import (
    service_ticket_create_schema,
    service_ticket_schema,
    service_ticket_update_schema,
    service_tickets_schema,
    ticket_mechanic_edit_schema,
)


@service_ticket_bp.post("/")
@token_required
def create_service_ticket(auth_customer_id):
    data = service_ticket_create_schema.load(request.get_json(silent=True) or {})
    ticket = ServiceTicket(
        description=data["description"],
        status=data["status"],
        customer_id=auth_customer_id,
    )
    db.session.add(ticket)
    db.session.commit()
    cache.clear()
    return service_ticket_schema.jsonify(ticket), 201


@service_ticket_bp.get("/")
@cache.cached(timeout=30, query_string=True)
def get_service_tickets():
    status = request.args.get("status")
    statement = db.select(ServiceTicket).order_by(ServiceTicket.id.desc())
    if status:
        statement = statement.where(ServiceTicket.status == status)
    tickets = db.session.scalars(statement).all()
    return jsonify(service_tickets_schema.dump(tickets))


@service_ticket_bp.get("/<int:ticket_id>")
def get_service_ticket(ticket_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    return service_ticket_schema.jsonify(ticket)


@service_ticket_bp.put("/<int:ticket_id>")
@mechanic_token_required
def update_service_ticket(auth_mechanic_id, ticket_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    data = service_ticket_update_schema.load(request.get_json(silent=True) or {})
    for field in ("description", "status"):
        if field in data:
            setattr(ticket, field, data[field])
    db.session.commit()
    cache.clear()
    return service_ticket_schema.jsonify(ticket)


@service_ticket_bp.put("/<int:ticket_id>/edit")
@mechanic_token_required
def edit_ticket_mechanics(auth_mechanic_id, ticket_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    data = ticket_mechanic_edit_schema.load(request.get_json(silent=True) or {})
    add_ids = set(data["add_ids"])
    remove_ids = set(data["remove_ids"])
    requested_ids = add_ids | remove_ids

    mechanics = []
    if requested_ids:
        mechanics = db.session.scalars(
            db.select(Mechanic).where(Mechanic.id.in_(requested_ids))
        ).all()
    mechanic_map = {mechanic.id: mechanic for mechanic in mechanics}
    missing_ids = sorted(requested_ids - mechanic_map.keys())
    if missing_ids:
        return jsonify({"message": "One or more mechanics were not found", "missing_ids": missing_ids}), 404

    current_ids = {mechanic.id for mechanic in ticket.mechanics}
    added = []
    removed = []
    for mechanic_id in add_ids:
        if mechanic_id not in current_ids:
            ticket.mechanics.append(mechanic_map[mechanic_id])
            added.append(mechanic_id)
    for mechanic_id in remove_ids:
        mechanic = mechanic_map[mechanic_id]
        if mechanic in ticket.mechanics:
            ticket.mechanics.remove(mechanic)
            removed.append(mechanic_id)

    db.session.commit()
    cache.clear()
    return jsonify(
        {
            "message": "Ticket mechanics updated",
            "added_ids": sorted(added),
            "removed_ids": sorted(removed),
            "ticket": service_ticket_schema.dump(ticket),
        }
    )


@service_ticket_bp.put("/<int:ticket_id>/assign-mechanic/<int:mechanic_id>")
@mechanic_token_required
def assign_mechanic(auth_mechanic_id, ticket_id, mechanic_id):
    return _change_single_mechanic(ticket_id, mechanic_id, add=True)


@service_ticket_bp.put("/<int:ticket_id>/remove-mechanic/<int:mechanic_id>")
@mechanic_token_required
def remove_mechanic(auth_mechanic_id, ticket_id, mechanic_id):
    return _change_single_mechanic(ticket_id, mechanic_id, add=False)


def _change_single_mechanic(ticket_id, mechanic_id, add):
    ticket = db.session.get(ServiceTicket, ticket_id)
    mechanic = db.session.get(Mechanic, mechanic_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    if not mechanic:
        return jsonify({"message": "Mechanic not found"}), 404
    if add and mechanic not in ticket.mechanics:
        ticket.mechanics.append(mechanic)
    if not add and mechanic in ticket.mechanics:
        ticket.mechanics.remove(mechanic)
    db.session.commit()
    cache.clear()
    action = "assigned to" if add else "removed from"
    return jsonify({"message": f"Mechanic {action} ticket", "ticket": service_ticket_schema.dump(ticket)})


@service_ticket_bp.put("/<int:ticket_id>/add-part/<int:part_id>")
@mechanic_token_required
def add_part_to_ticket(auth_mechanic_id, ticket_id, part_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    part = db.session.get(Inventory, part_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    if not part:
        return jsonify({"message": "Inventory part not found"}), 404
    if part not in ticket.parts:
        ticket.parts.append(part)
        db.session.commit()
        cache.clear()
        message = "Part added to ticket"
    else:
        message = "Part is already attached to this ticket"
    return jsonify({"message": message, "ticket": service_ticket_schema.dump(ticket)})


@service_ticket_bp.put("/<int:ticket_id>/remove-part/<int:part_id>")
@mechanic_token_required
def remove_part_from_ticket(auth_mechanic_id, ticket_id, part_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    part = db.session.get(Inventory, part_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    if not part:
        return jsonify({"message": "Inventory part not found"}), 404
    if part in ticket.parts:
        ticket.parts.remove(part)
        db.session.commit()
        cache.clear()
    return jsonify({"message": "Part removed from ticket", "ticket": service_ticket_schema.dump(ticket)})


@service_ticket_bp.delete("/<int:ticket_id>")
@mechanic_token_required
def delete_service_ticket(auth_mechanic_id, ticket_id):
    ticket = db.session.get(ServiceTicket, ticket_id)
    if not ticket:
        return jsonify({"message": "Service ticket not found"}), 404
    db.session.delete(ticket)
    db.session.commit()
    cache.clear()
    return jsonify({"message": "Service ticket deleted"})
